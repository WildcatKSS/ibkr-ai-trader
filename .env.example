# =============================================================================
# .env.example — IBKR AI Trader environment variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or run deploy/setup.sh — it generates .env automatically with
# DB_PASSWORD, SECRET_KEY, and DOMAIN pre-filled.
# =============================================================================

# ── External API keys (fill in manually) ─────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
IBKR_PORT=7497              # TWS paper: 7497 | IB Gateway paper: 4002 | TWS live: 7496 | IB GW live: 4001
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
FINNHUB_API_KEY=your_finnhub_api_key
SMTP_PASSWORD=your_smtp_password_or_app_password

# ── Generated automatically by setup.sh — do not change manually ─────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ibkr_trader
DB_USER=ibkr_trader
DB_PASSWORD=                # Generated by deploy/setup.sh
SECRET_KEY=                 # Generated by deploy/setup.sh
DOMAIN=                     # Entered during setup (e.g. trader.example.com)
